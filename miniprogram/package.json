{
  "name": "ygo-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "游戏王决斗者卡查 · 微信/抖音小程序（Taro + React）",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass",
    "framework": "react"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:tt": "taro build --type tt --watch",
    "dev:h5": "taro build --type h5 --watch"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.17",
    "@tarojs/cli": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.3.1",
    "@types/webpack-env": "^1.18.4",
    "babel-preset-taro": "4.2.0",
    "postcss": "^8.4.35",
    "react-refresh": "^0.14.0",
    "stylelint": "^16.0.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0"
  }
}
