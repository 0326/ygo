{
	"name": "ygo",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"cloudflare": {
		"label": "Vite React Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
		"publish": true
	},
	"dependencies": {
		"hono": "4.11.1",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-router-dom": "^7.17.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@eslint/js": "9.39.1",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.48.0",
		"vite": "^7.0.0",
		"wrangler": "4.88.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "vite",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"data:build": "node scripts/build-data.mjs",
		"data:sync": "node scripts/sync-data.mjs",
		"data:sync:local": "node scripts/sync-data.mjs --apply local",
		"data:sync:remote": "node scripts/sync-data.mjs --apply remote",
		"db:migrate": "wrangler d1 execute ygo-db --local --file=migrations/0001_init.sql",
		"db:seed": "wrangler d1 execute ygo-db --local --file=data/seed.sql",
		"db:setup": "npm run db:migrate && npm run db:seed",
		"db:migrate:remote": "wrangler d1 execute ygo-db --remote --file=migrations/0001_init.sql",
		"db:seed:remote": "wrangler d1 execute ygo-db --remote --file=data/seed.sql",
		"wp:collect": "node scripts/collect-wallpapers.mjs",
		"wp:migrate": "wrangler d1 execute ygo-db --local --file=migrations/0002_wallpapers.sql",
		"wp:seed": "wrangler d1 execute ygo-db --local --file=data/wallpapers.seed.sql",
		"wp:migrate:remote": "wrangler d1 execute ygo-db --remote --file=migrations/0002_wallpapers.sql",
		"wp:seed:remote": "wrangler d1 execute ygo-db --remote --file=data/wallpapers.seed.sql"
	},
	"type": "module"
}
